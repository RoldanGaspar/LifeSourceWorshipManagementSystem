rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Members collection - special rules for signup flow
    match /members/{memberId} {
      // Allow read for signup flow (checking invites and admin status)
      // This is needed because the app queries members BEFORE user is authenticated
      allow read: if true;
      
      // Only authenticated users can write
      // Users can only write their own document
      allow write: if request.auth != null && request.auth.uid == memberId;
      
      // Allow delete for cleanup of invite documents
      allow delete: if request.auth != null;
    }
    
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Teams collection - authenticated users can read/write
    match /teams/{teamId} {
      allow read, write: if request.auth != null;
    }
    
    // Songs collection - authenticated users can read/write
    match /songs/{songId} {
      allow read, write: if request.auth != null;
    }
    
    // Services/Events collection - authenticated users can read/write
    match /services/{serviceId} {
      allow read, write: if request.auth != null;
    }
    
    // Schedules collection - authenticated users can read/write
    match /schedules/{scheduleId} {
      allow read, write: if request.auth != null;
    }
    
    // Catch-all for other collections - require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}